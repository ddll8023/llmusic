{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
	"ignoreDeprecations": "6.0",
		"strict": true,
		"esModuleInterop": true,
		"outDir": "./dist-ts",
		"rootDir": ".",
		"sourceMap": true,
		"declaration": false,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true
	},
	"include": [
		"**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist-ts",
		"build"
	]
}
