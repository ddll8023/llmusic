{
	"name": "llmusic-electron",
	"productName": "LLMusic",
	"version": "1.0.0",
	"description": "",
	"main": "main.js",
	"private": true,
	"scripts": {
		"dev": "concurrently \"npm --prefix ../sys_vue run dev\" \"wait-on http://127.0.0.1:9753 && electron .\"",
		"dev:electron": "electron .",
		"build": "npm --prefix ../sys_vue run build",
		"pack": "electron-builder"
	},
	"dependencies": {
		"ffmpeg-static": "^5.2.0",
		"ffprobe-static": "^3.1.0",
		"fluent-ffmpeg": "^2.1.3",
		"lowdb": "^7.0.1",
		"music-metadata": "^11.2.3",
		"uuid": "^11.1.0"
	},
	"devDependencies": {
		"concurrently": "^8.2.2",
		"electron": "^36.5.0",
		"electron-builder": "^26.0.12",
		"wait-on": "^7.2.0"
	},
	"build": {
		"appId": "com.electron.llmusic",
		"productName": "LLMusic",
		"asarUnpack": [
			"**/node_modules/ffmpeg-static/**",
			"**/node_modules/ffprobe-static/**"
		],
		"fileAssociations": [
			{
				"ext": "mp3",
				"name": "MP3 Audio File",
				"description": "MP3 音频文件",
				"role": "Editor"
			},
			{
				"ext": "flac",
				"name": "FLAC Audio File",
				"description": "FLAC 无损音频文件",
				"role": "Editor"
			},
			{
				"ext": "wav",
				"name": "WAV Audio File",
				"description": "WAV 音频文件",
				"role": "Editor"
			},
			{
				"ext": "m4a",
				"name": "M4A Audio File",
				"description": "M4A 音频文件",
				"role": "Editor"
			},
			{
				"ext": "ogg",
				"name": "OGG Audio File",
				"description": "OGG 音频文件",
				"role": "Editor"
			},
			{
				"ext": "aac",
				"name": "AAC Audio File",
				"description": "AAC 音频文件",
				"role": "Editor"
			}
		]
	}
}
