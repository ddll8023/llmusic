{
	"name": "llmusic-electron",
	"productName": "LLMusic",
	"version": "1.0.0",
	"description": "",
	"main": "dist-ts/main.js",
	"private": true,
	"scripts": {
		"dev": "concurrently \"npm --prefix ../sys_vue run dev\" \"wait-on http://127.0.0.1:9753 && npm run tsc && electron ./dist-ts\"",
		"dev:electron": "electron ./dist-ts",
		"dev-runner": "tsc && node ./dist-ts/dev-runner.js",
		"tsc": "tsc",
		"tsc:watch": "tsc --watch",
		"type-check": "tsc --noEmit",
		"build": "npm --prefix ../sys_vue run build",
		"build:backend": "uv run --directory ../backend pyinstaller --onefile --name backend --distpath ../backend/dist ../backend/entry.py",
		"pack": "electron-builder",
		"dist:dir": "npm run build && npm run build:backend && tsc && electron-builder --win dir",
		"dist:win": "npm run build && npm run build:backend && tsc && electron-builder --win"
	},
	"dependencies": {
		"ffmpeg-static": "^5.2.0",
		"ffprobe-static": "^3.1.0",
		"fluent-ffmpeg": "^2.1.3",
		"lowdb": "^7.0.1",
		"music-metadata": "^11.2.3",
		"node-id3": "^0.2.9",
		"uuid": "^11.1.0"
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"concurrently": "^8.2.2",
		"electron": "^36.5.0",
		"electron-builder": "^26.0.12",
		"typescript": "^6.0.3",
		"wait-on": "^7.2.0"
	},
	"build": {
		"appId": "com.llmusic.desktop",
		"productName": "LLMusic",
		"directories": {
			"output": "../release"
		},
		"files": [
			"**/*"
		],
		"extraResources": [
			{
				"from": "../backend/dist/backend.exe",
				"to": "backend/backend.exe"
			},
			{
				"from": "../backend/app/credential/credential.json",
				"to": "backend/credential/credential.json"
			},
			{
				"from": "../sys_vue/dist",
				"to": "sys_vue/dist",
				"filter": [
					"**/*"
				]
			}
		],
		"asarUnpack": [
			"**/node_modules/ffmpeg-static/**",
			"**/node_modules/ffprobe-static/**"
		],
		"fileAssociations": [
			{
				"ext": "mp3",
				"name": "MP3 Audio File",
				"description": "MP3 音频文件",
				"role": "Editor"
			},
			{
				"ext": "flac",
				"name": "FLAC Audio File",
				"description": "FLAC 无损音频文件",
				"role": "Editor"
			},
			{
				"ext": "wav",
				"name": "WAV Audio File",
				"description": "WAV 音频文件",
				"role": "Editor"
			},
			{
				"ext": "m4a",
				"name": "M4A Audio File",
				"description": "M4A 音频文件",
				"role": "Editor"
			},
			{
				"ext": "ogg",
				"name": "OGG Audio File",
				"description": "OGG 音频文件",
				"role": "Editor"
			},
			{
				"ext": "aac",
				"name": "AAC Audio File",
				"description": "AAC 音频文件",
				"role": "Editor"
			}
		],
		"win": {
			"target": [
				"dir",
				"nsis"
			],
			"icon": "build/icon.ico"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "LLMusic"
		}
	}
}
